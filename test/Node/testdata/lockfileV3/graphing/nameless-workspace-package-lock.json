{
  "name": "nameless-ws-root",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "nameless-ws-root",
      "version": "1.0.0",
      "workspaces": [
        "packages/*"
      ],
      "dependencies": {
        "root-dep": "^1.0.0"
      }
    },
    "node_modules/pkg-a": {
      "resolved": "packages/pkg-a",
      "link": true
    },
    "node_modules/root-dep": {
      "version": "1.0.0",
      "resolved": "https://registry.npmjs.org/root-dep/-/root-dep-1.0.0.tgz"
    },
    "node_modules/ws-dep": {
      "version": "1.0.0",
      "resolved": "https://registry.npmjs.org/ws-dep/-/ws-dep-1.0.0.tgz"
    },
    "packages/pkg-a": {
      "version": "1.0.0",
      "dependencies": {
        "ws-dep": "^1.0.0"
      }
    }
  }
}
